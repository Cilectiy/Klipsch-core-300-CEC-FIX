#!/bin/sh

PIDFILE="/opt/var/run/klipsch.pid"

start() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "Klipsch watcher is already running."
        return
    fi

    echo "Starting Klipsch watcher..."

    (
        while true; do
            exec /opt/bin/python3 /opt/root/klipsch.py
            sleep 5
        done
    ) &

    echo $! > "$PIDFILE"
}

stop() {
    echo "Stopping Klipsch watcher..."

    if [ -f "$PIDFILE" ]; then
        kill "$(cat "$PIDFILE")"
        rm -f "$PIDFILE"
    fi
}

status() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "Klipsch watcher is running."
    else
        echo "Klipsch watcher is stopped."
    fi
}

case "$1" in
    start) start ;;
    stop) stop ;;
    restart) stop; sleep 1; start ;;
    status) status ;;
esac
